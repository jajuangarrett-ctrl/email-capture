{
  "name": "email-capture",
  "version": "0.2.5",
  "description": "Quick voice/text capture of emails. On save, GPT-4o drafts the email in Franklin's standard format and writes it to AI Team/Team_Inbox.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run"
  },
  "keywords": ["obsidian-plugin", "obsidian", "email", "capture"],
  "author": "Franklin Garrett",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.7",
    "builtin-modules": "3.3.0",
    "esbuild": "0.20.2",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.4.5",
    "vitest": "^1.6.0"
  }
}
